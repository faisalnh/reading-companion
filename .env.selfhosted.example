# Self-Hosted Reading Buddy Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# DATABASE
# =============================================================================
# PostgreSQL Password (generate with: openssl rand -base64 32)
POSTGRES_PASSWORD=your-secure-postgres-password-here

# Database URL for application (via PgBouncer)
DATABASE_URL=postgresql://reading_buddy_app:your-secure-postgres-password-here@pgbouncer:5432/reading_buddy

# =============================================================================
# NEXTAUTH
# =============================================================================
# NextAuth URL (your public domain)
NEXTAUTH_URL=https://reading-buddy.yourdomain.com

# NextAuth Secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=your-nextauth-secret-here

# =============================================================================
# GOOGLE OAUTH
# =============================================================================
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# =============================================================================
# REDIS
# =============================================================================
REDIS_URL=redis://redis:6379

# =============================================================================
# MINIO STORAGE
# =============================================================================
# MinIO endpoint (without http/https)
MINIO_ENDPOINT=minio.yourdomain.com
MINIO_PORT=443
MINIO_USE_SSL=true
MINIO_ACCESS_KEY=your-minio-access-key
MINIO_SECRET_KEY=your-minio-secret-key
MINIO_BUCKET_NAME=reading-buddy

# =============================================================================
# AI CONFIGURATION
# =============================================================================
# AI Provider: "local" or "cloud"
AI_PROVIDER=local

# Google Gemini (if using cloud)
GEMINI_API_KEY=your-gemini-api-key

# Local AI APIs (if using local)
RAG_API_URL=http://172.16.0.65:8000
DIFFUSER_API_URL=http://172.16.0.165:8000
NEXT_PUBLIC_RAG_API_URL=http://172.16.0.65:8000

# =============================================================================
# EMAIL (SMTP)
# =============================================================================
# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@yourdomain.com

# Alternative: Resend (recommended)
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_USER=resend
# SMTP_PASSWORD=re_your_api_key
# SMTP_FROM=noreply@yourdomain.com

# =============================================================================
# APPLICATION
# =============================================================================
# Public application URL
NEXT_PUBLIC_APP_URL=https://reading-buddy.yourdomain.com

# Node environment
NODE_ENV=production

# Application port
PORT=3000

# =============================================================================
# PGADMIN (Optional - only if using --profile tools)
# =============================================================================
PGADMIN_EMAIL=admin@reading-buddy.local
PGADMIN_PASSWORD=your-pgadmin-password

# =============================================================================
# BACKUP CONFIGURATION
# =============================================================================
# Number of days to retain backups
BACKUP_RETENTION_DAYS=30
